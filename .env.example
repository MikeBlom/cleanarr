BASE_URL=https://cleanarr.example.com
DEBUG=false
DATABASE_URL=sqlite:////data/cleanarr.db

# Plex OAuth
PLEX_CLIENT_ID=                       # optional — default works fine; only change for multi-instance setups
PLEX_CLIENT_NAME=CleanArr
PLEX_ADMIN_PLEX_IDS=                  # comma-separated Plex user IDs → auto admin+approved

# Plex server
PLEX_SERVER_URL=http://192.168.1.x:32400
PLEX_ADMIN_TOKEN=your_plex_token_here

# Docker path mapping: Plex sees /data/media, container mounts it at /mnt/media
PLEX_PATH_PREFIX_FROM=/data/media
PLEX_PATH_PREFIX_TO=/mnt/media

# cleanmedia
CLEANMEDIA_BIN=cleanmedia
ALLOWED_MEDIA_DIRS=/mnt/media

# Sessions
SESSION_COOKIE_NAME=cleanarr_session
SESSION_MAX_AGE_DAYS=30

# Worker
WORKER_POLL_INTERVAL_SEC=2
